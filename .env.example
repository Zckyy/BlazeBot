# Discord bot token (Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Application ID (Discord Developer Portal -> General Information -> Application ID)
DISCORD_CLIENT_ID=

# Test server ID for fast guild-scoped command deployment during dev.
# Leave empty to deploy commands globally (~1 hour to propagate).
DISCORD_GUILD_ID=

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# BlazeBot AI chat. OPENROUTER_API_KEY is required only when AI_CHAT_ENABLED=true.
AI_CHAT_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Global kill switch for explicitly requested web searches.
AI_WEB_SEARCH_ENABLED=true
AI_MAX_OUTPUT_TOKENS=700
AI_CONTEXT_TOKEN_BUDGET=12000
AI_MAX_CONCURRENT_REQUESTS=2
# Set to 0 for no daily per-server spending cap.
AI_DAILY_BUDGET_USD=1
