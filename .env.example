# Discord bot token (Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Application ID (Discord Developer Portal -> General Information -> Application ID)
DISCORD_CLIENT_ID=

# Test server ID for fast guild-scoped command deployment during dev.
# Leave empty to deploy commands globally (~1 hour to propagate).
DISCORD_GUILD_ID=

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
